# CatobiGato FastAPI Backend — Environment Variables
# Copy to .env and fill in your values

# App
DEBUG=false

# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=catobigato
DB_USER=catobigato
DB_PASSWORD=your_db_password_here

# Keycloak (KeyToMarvel.com — catobigato realm)
KEYCLOAK_URL=https://www.keytomarvel.com
KEYCLOAK_REALM=catobigato
KEYCLOAK_CLIENT_ID=catobigato

# CORS — comma-separated list as JSON array
# Development: ["http://localhost:8081"]
# Production:  ["https://catobigato.com"]
CORS_ORIGINS=["http://localhost:5173"]
